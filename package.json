{
  "name": "video-processing-server",
  "version": "1.0.0",
  "description": "FFmpeg video segment crop worker – subscribes to Pub/Sub, crops clips, uploads to Firebase Storage & Cloudflare Stream",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "dev": "tsx --env-file=.env --watch src/server.ts",
    "backfill": "tsx --env-file=.env src/scripts/backfill.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}
